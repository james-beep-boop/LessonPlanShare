# Git history — not needed in image
.git/
.github/

# Local environment secrets — entrypoint writes .env at runtime
.env

# Vendor will be installed by Dockerfile via composer install
# (include composer.json and composer.lock, exclude the vendor dir itself)
vendor/

# Node (not used — this project uses CDN-only)
node_modules/

# Compiled caches — regenerated by entrypoint at runtime
bootstrap/cache/*.php
storage/framework/cache/
storage/framework/sessions/
storage/framework/views/

# Log files
storage/logs/*.log

# Uploaded lesson files — use the Docker volume instead
storage/app/public/lessons/*
!storage/app/public/lessons/.gitkeep

# Dev / documentation files not needed in the image
*.md
STRESS_TEST_PLAN.md
DEPLOYMENT.md
TECHNICAL_DESIGN.md
CURRENT_STATUS.md
UPDATE_SITE.sh
VERSION
.claude/
